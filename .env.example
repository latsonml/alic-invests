# Resend (set in DigitalOcean App Platform as an encrypted RUN_TIME secret)
RESEND_API_KEY=

# Email settings
NOTIFY_EMAIL=michael@aliccapital.com
FROM_EMAIL=Alic <invest@communications.alicinvestments.com>

# Comma-separated origins allowed to call the invest API
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://alicinvestments.com,https://www.alicinvestments.com

# Local API port for `npm run dev:api`
LOCAL_API_PORT=8787

# Optional override for frontend (production default: /api/alic/invest-submit)
# VITE_INVEST_API_URL=/api/alic/invest-submit
